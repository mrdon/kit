# Host port bindings for the docker compose stack. Override these (and
# the matching ports inside DATABASE_URL / REDIS_URL below) if you have a
# second clone of this repo running its own compose stack at the same
# time — otherwise both stacks will fight over the same host ports.
PG_PORT=5489
REDIS_PORT=6389
PORT=8488

DATABASE_URL=postgres://kit:kit@localhost:5489/kit?sslmode=disable
REDIS_URL=redis://localhost:6389
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
ANTHROPIC_API_KEY=
ENCRYPTION_KEY=  # 32-byte hex string for AES-256-GCM (generate with: openssl rand -hex 32)
